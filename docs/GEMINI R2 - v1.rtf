    g.strokeCircle(0, -75, 15);\
  \} else if (bossKey === 'mochiQueen') \{\
    g.fillCircle(0, -40, 40);\
    g.fillTriangle(-15, -75, -5, -90, 5, -75);\
    g.fillTriangle(-5, -75, 5, -95, 15, -75);\
    g.fillTriangle(5, -75, 15, -90, 25, -75);\
  \} else if (bossKey === 'insulinAdmiral') \{\
    g.fillRect(-40, -20, 80, 30);\
    g.fillTriangle(-40, -5, -70, -5, -40, 10);\
    g.fillRect(40, -10, 10, 10);\
  \} else if (bossKey === 'rastaCorpCeo') \{\
    g.fillCircle(0, -70, 18);\
    g.fillRect(-15, -50, 30, 60);\
    g.fillRect(20, -20, 20, 15);\
  \}\
  g.restore();\
\
  var textObj = scene.add.text(W/2, 420, '', \{\
    fontFamily: 'Inconsolata,monospace',\
    fontSize: '22px',\
    color: '#ffddaa',\
    align: 'center'\
  \}).setOrigin(0.5).setDepth(91).setScrollFactor(0);\
\
  var seq = [pd.edLine, pd.bossLine];\
  for (var i = 0; i < pd.lines.length; i++) \{\
    seq.push(pd.lines[i]);\
  \}\
\
  var delay = 500;\
  for (var j = 0; j < seq.length; j++) \{\
    (function(idx, txt) \{\
      scene.time.delayedCall(delay, function() \{\
        textObj.setText(txt);\
      \});\
    \})(j, seq[j]);\
    delay += 1200;\
  \}\
  \
  scene.time.delayedCall(delay + 800, function() \{\
    scene.tweens.add(\{\
      targets: [g, textObj],\
      alpha: 0,\
      duration: 600,\
      onComplete: function() \{\
        g.destroy();\
        try \{ textObj.destroy(); \} catch(e) \{\}\
        if (onComplete) onComplete();\
      \}\
    \});\
  \});\
\}\
